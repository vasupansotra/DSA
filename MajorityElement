class Solution{
    public int me(int[] arr){
        int el = 0;
        int count = 0;
        for(int i=0;i<arr.length;i++){
            if(count == 0) el = arr[i];
            else if (arr[i] == el) count++;
            else count--;
        }
        return el;
    }
    public static void main(String a[]){
        Solution sol = new Solution();
        int[] arr = {1,2,2,1,2};
        int ans = sol.me(arr);
        System.out.println("Answer is : " + ans);
    } 
}
