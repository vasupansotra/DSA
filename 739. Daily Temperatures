class Solution {
    public int[] dailyTemperatures(int[] temperatures) {
         int n = temperatures.length;
            int[] ans = new int[n];
            Stack<Integer> stack = new Stack<>();

            for (int i=0;i<n;i++) {
                while (!stack.isEmpty() && temperatures[stack.peek()] < temperatures[i]) {
                    int prevIndex = stack.pop(); // Purana index nikala
                    ans[prevIndex] = i - prevIndex; // Dino ka gap calculate kiya
                }
                stack.push(i);
            }
            return ans;
    }
}
