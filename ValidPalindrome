class Solution {
    public boolean isPalindrome(String s) {
        String x = s.toLowerCase();
        String y = x.replaceAll("[^a-z0-9]","");
        int left = 0;
        int right = y.length()-1;
        while(left<right){
            if(y.charAt(left) != y.charAt(right)){
                return false;
            }
            else{
                left++;
                right--;
            }
        }
        return true;
    }
}
